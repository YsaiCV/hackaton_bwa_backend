# ─── Google Gemini ───────────────────────────────────────────────────────────
# API key de Google AI Studio / Vertex AI para autenticar las llamadas al modelo
GEMINI_API_KEY=abcdddddd
# Nombre del modelo Gemini a usar (ej: gemini-2.0-flash, gemini-1.5-pro)
# Si se omite, el agente de búsqueda usará 'gemini-flash-latest' por defecto
GEMINI_MODEL=gemini-flash-latest

# ─── Servidor ────────────────────────────────────────────────────────────────
# Puerto en el que escucha la aplicación (por defecto: 3000)
PORT=3000
