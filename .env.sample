# ─── Google Gemini ───────────────────────────────────────────────────────────
# API key de Google AI Studio / Vertex AI para autenticar las llamadas al modelo
GEMINI_API_KEY=abcdddddd
# Nombre del modelo Gemini a usar (ej: gemini-2.0-flash, gemini-1.5-pro)
# Si se omite, el agente de búsqueda usará 'gemini-flash-latest' por defecto
GEMINI_MODEL=gemini-flash-latest

# ─── Servidor ────────────────────────────────────────────────────────────────
# Puerto en el que escucha la aplicación (por defecto: 3000)
PORT=3000

# ─── Base de datos ───────────────────────────────────────────────────────────
# Host de PostgreSQL (usar 'localhost' para local, nombre del servicio en Docker)
POSTGRES_HOST=localhost
# Puerto de PostgreSQL (por defecto: 5432)
POSTGRES_PORT=5432
# Usuario de PostgreSQL
POSTGRES_USER=postgres
# Contraseña de PostgreSQL
POSTGRES_PASSWORD=your_password_here
# Nombre de la base de datos
POSTGRES_DB=hackaton_bwa
